<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>后台管理</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-shell">
    <aside class="admin-sidebar">
      <div class="admin-brand">
        <h1>后台管理</h1>
        <span><%= user.username %> · <%= user.role === 'superadmin' ? '超管' : '管理员' %></span>
      </div>
      <nav class="admin-nav">
        <button type="button" class="admin-nav-item active" data-tab="users">用户与权限</button>
        <button type="button" class="admin-nav-item" data-tab="audit">操作日志</button>
        <% if (user.role === 'superadmin') { %>
          <button type="button" class="admin-nav-item" data-tab="maintenance">系统维护</button>
        <% } %>
      </nav>
      <div class="admin-sidebar-foot">
        <a class="btn btn-secondary btn-sm" href="/">文件管理</a>
      </div>
    </aside>

    <main class="admin-content">
      <section class="admin-tab active" id="tab-users">
        <div class="content-head">
          <div>
            <h2>用户与权限</h2>
            <p>管理员可管理普通用户，超管可管理管理员账号。</p>
          </div>
          <div class="head-actions">
            <button type="button" class="btn btn-secondary btn-sm" id="btn-generate-user">快速生成用户</button>
            <button type="button" class="btn btn-primary btn-sm" id="btn-new-user">新建用户</button>
          </div>
        </div>

        <div class="admin-panel">
          <div class="user-table-wrap">
            <table>
              <thead>
                <tr>
                  <th>账号</th>
                  <th>备注</th>
                  <th>角色</th>
                  <th>状态</th>
                  <th>权限</th>
                  <th>更新时间</th>
                  <th>操作</th>
                </tr>
              </thead>
              <tbody id="users-body"></tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="admin-tab" id="tab-audit">
        <div class="content-head">
          <div>
            <h2>操作日志</h2>
            <p>可按账号、文件夹和日期范围筛选。</p>
          </div>
          <button type="button" class="btn btn-secondary btn-sm" id="btn-refresh-logs">刷新</button>
        </div>

        <div class="admin-panel">
          <form class="audit-filters" id="audit-filters">
            <input type="text" id="filter-username" placeholder="账号">
            <select id="filter-folder">
              <option value="">全部文件夹</option>
            </select>
            <input type="date" id="filter-from">
            <input type="date" id="filter-to">
            <button type="submit" class="btn btn-primary btn-sm">筛选</button>
          </form>
          <div class="audit-list" id="audit-list"></div>
        </div>
      </section>

      <% if (user.role === 'superadmin') { %>
        <section class="admin-tab" id="tab-maintenance">
          <div class="content-head">
            <div>
              <h2>系统维护</h2>
              <p>拉取最新代码、安装依赖，并在全部成功后重启服务。</p>
            </div>
            <div class="head-actions">
              <button type="button" class="btn btn-secondary btn-sm" id="btn-refresh-maintenance">刷新状态</button>
              <button type="button" class="btn btn-danger btn-sm" id="btn-run-maintenance">更新并重启</button>
            </div>
          </div>

          <div class="admin-panel">
            <div class="maintenance-message" id="maintenance-message">就绪</div>
            <div class="maintenance-status" id="maintenance-status"></div>
            <pre class="maintenance-log" id="maintenance-log">暂无日志</pre>
          </div>
        </section>
      <% } %>
    </main>
  </div>

  <div class="modal" id="user-modal" style="display:none">
    <div class="modal-backdrop"></div>
    <div class="modal-box user-modal-box">
      <h3 id="user-modal-title">新建用户</h3>
      <form id="user-form">
        <input type="hidden" id="user-id">
        <div class="form-grid">
          <div class="form-group">
            <label>用户名</label>
            <input type="text" id="user-username" required>
          </div>
          <div class="form-group">
            <label>密码 <span class="text-muted" id="password-hint"></span></label>
            <input type="text" id="user-password" autocomplete="new-password">
          </div>
          <div class="form-group">
            <label>角色</label>
            <select id="user-role">
              <option value="user">普通用户</option>
              <option value="admin">管理员</option>
            </select>
          </div>
          <div class="form-group">
            <label>备注</label>
            <input type="text" id="user-remark" placeholder="例如：张三 / 财务部 / 测试设备">
          </div>
        </div>

        <div class="form-group form-check">
          <input type="checkbox" id="user-enabled" checked>
          <label for="user-enabled" style="margin:0">启用</label>
        </div>

        <div class="permission-editor">
          <div class="permission-head">
            <label>目录权限（递归）</label>
            <button type="button" class="btn btn-secondary btn-sm" id="btn-add-permission">添加权限</button>
          </div>
          <div class="permission-list" id="permission-list"></div>
        </div>

        <div class="modal-actions">
          <button type="button" class="btn btn-secondary modal-close">取消</button>
          <button type="submit" class="btn btn-primary">保存</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    window.ADMIN_CONFIG = { currentUser: <%- JSON.stringify(user).replace(/</g, '\\u003c') %> };
  </script>
  <script src="/js/admin.js"></script>
</body>
</html>
