<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>局域网文件服务器</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/explorer.css">
</head>
<body class="explorer-page">
  <div class="explorer-app" id="explorer-app">
    <header class="explorer-toolbar">
      <div class="toolbar-left">
        <button type="button" class="tb-btn" id="btn-back" title="后退" disabled>←</button>
        <button type="button" class="tb-btn" id="btn-up" title="上级">↑</button>
        <div class="path-bar" id="path-bar">
          <div class="breadcrumb" id="breadcrumb" title="点击输入目录路径"></div>
          <form class="path-form" id="path-form" style="display:none">
            <input type="text" id="path-input" autocomplete="off" spellcheck="false" aria-label="目录路径">
          </form>
        </div>
      </div>
      <div class="toolbar-center">
        <div class="search-box">
          <input type="text" id="search-input" placeholder="搜索当前目录..." />
        </div>
      </div>
      <div class="toolbar-right">
        <button type="button" class="tb-btn view-btn active" data-view="grid" title="图标">▦</button>
        <button type="button" class="tb-btn view-btn" data-view="list" title="列表">☰</button>
        <button type="button" class="tb-btn admin-only" id="btn-new-folder" title="新建文件夹">+ 文件夹</button>
        <a class="tb-btn admin-only" id="btn-admin" href="/admin" title="后台管理">后台</a>
        <span class="user-badge" id="user-badge">访客</span>
        <button type="button" class="tb-btn" id="btn-login">登录</button>
        <button type="button" class="tb-btn admin-only" id="btn-logout" style="display:none">退出</button>
      </div>
    </header>

    <main class="explorer-main" id="explorer-main">
      <div class="empty-hint" id="empty-hint" style="display:none">此文件夹为空</div>
      <div class="entry-grid" id="entry-container"></div>
      <div class="selection-box" id="selection-box" style="display:none"></div>
    </main>

    <div class="status-bar">
      <span id="status-text">就绪</span>
      <span id="selection-info"></span>
    </div>

    <!-- 拖拽上传遮罩 -->
    <div class="drop-overlay admin-only" id="drop-overlay" style="display:none">
      <div class="drop-overlay-inner">松开鼠标上传文件</div>
    </div>

    <!-- 右键菜单 -->
    <div class="context-menu" id="context-menu" style="display:none"></div>
    <div class="context-menu-tip" id="context-menu-tip" style="display:none"></div>

    <!-- 登录弹窗 -->
    <div class="modal" id="login-modal" style="display:none">
      <div class="modal-backdrop"></div>
      <div class="modal-box">
        <h3>管理员登录</h3>
        <div class="alert alert-error" id="login-error" style="display:none"></div>
        <form id="login-form">
          <div class="form-group">
            <label>用户名</label>
            <input type="text" name="username" required autofocus>
          </div>
          <div class="form-group">
            <label>密码</label>
            <input type="password" name="password" required>
          </div>
          <div class="modal-actions">
            <button type="button" class="btn btn-secondary" id="login-cancel">取消</button>
            <button type="submit" class="btn btn-primary">登录</button>
          </div>
        </form>
      </div>
    </div>

    <!-- 重命名弹窗 -->
    <div class="modal" id="rename-modal" style="display:none">
      <div class="modal-backdrop"></div>
      <div class="modal-box">
        <h3 id="rename-title">重命名</h3>
        <form id="rename-form">
          <input type="hidden" id="rename-id">
          <input type="hidden" id="rename-type">
          <div class="form-group">
            <input type="text" id="rename-value" required>
          </div>
          <div class="modal-actions">
            <button type="button" class="btn btn-secondary modal-close">取消</button>
            <button type="submit" class="btn btn-primary">确定</button>
          </div>
        </form>
      </div>
    </div>

    <!-- 移动到弹窗 -->
    <div class="modal" id="move-modal" style="display:none">
      <div class="modal-backdrop"></div>
      <div class="modal-box">
        <h3>移动到</h3>
        <p class="modal-file" id="move-hint"></p>
        <div class="folder-picker" id="folder-picker"></div>
        <p class="move-target-hint" id="move-target-hint">请选择目标文件夹</p>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary modal-close">取消</button>
          <button type="button" class="btn btn-primary" id="btn-confirm-move" disabled>确认移动</button>
        </div>
      </div>
    </div>
    <!-- 下载链接弹窗 -->
    <div class="modal" id="link-modal" style="display:none">
      <div class="modal-backdrop"></div>
      <div class="modal-box">
        <h3>下载链接</h3>
        <p class="modal-file" id="link-file-name"></p>
        <div class="link-box">
          <input type="text" id="download-link-input" readonly>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary modal-close">关闭</button>
          <button type="button" class="btn btn-primary" id="btn-copy-download-link">复制链接</button>
        </div>
      </div>
    </div>
  </div>
  <script>
    window.EXPLORER_CONFIG = { maxUploadSizeMB: <%= maxUploadSizeMB %> };
  </script>
  <script src="/js/explorer.js"></script>
</body>
</html>
